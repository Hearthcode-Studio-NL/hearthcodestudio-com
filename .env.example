# ============================================================
# hearthcodestudio-com — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored; `.env.example` is committed as
# the canonical list of variables the project expects.
#
# Naming convention:
#   NEXT_PUBLIC_*  — exposed to the browser bundle in Next.js projects
#   (no prefix)    — server-only, never shipped to the client
#
# Mark each variable: (required) or (optional).
# ============================================================

# ------------------------------------------------------------
# Site identity
# ------------------------------------------------------------

# (required) Canonical site URL, no trailing slash.
# Used for OG metadata, sitemap, absolute links.
NEXT_PUBLIC_SITE_URL=https://hearthcodestudio.com

# ------------------------------------------------------------
# Third-party services (optional — wire when needed)
# ------------------------------------------------------------

# (optional) Sentry DSN for client error tracking. Leave blank in dev.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# (optional) Plausible analytics — domain to report traffic against.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=hearthcodestudio.com
