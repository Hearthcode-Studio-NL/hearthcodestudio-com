# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/lighthouseci
/.lighthouseci

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.swp
*.swo
.idea/

# one-off ship/deploy helper scripts
ship-*.ps1

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real values, always commit the example.
.env
.env.local
.env.*.local
.env.production
.env.development
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
